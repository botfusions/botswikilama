{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noImplicitOverride": true,
    "types": ["node"],
    "ignoreDeprecations": "6.0",
    "noEmit": true
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "dist", "_js_backup"]
}
